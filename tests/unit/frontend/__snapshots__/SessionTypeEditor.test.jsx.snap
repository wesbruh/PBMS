            <button
              class="mt-2 flex items-center gap-1 text-xs text-[#AB8C4B] hover:text-[#725e32] underline cursor-pointer"
              type="button"
            >
              <span
                data-testid="icon-plus"
              />
               Add bullet point
            </button>
          </div>
          <div
            class="flex items-center gap-3 pt-2"
          >
            <input
              class="h-4 w-4"
              id="active-toggle"
              type="checkbox"
            />
            <label
              class="text-md"
              for="active-toggle"
            >
              Visible to clients (active)
            </label>
          </div>
        </div>
