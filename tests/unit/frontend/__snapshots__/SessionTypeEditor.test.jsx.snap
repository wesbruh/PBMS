              <span
                data-testid="icon-plus"
              />
               Add bullet point
            </button>
          </div>
          <div
            class="flex items-start gap-3 rounded-lg border border-[#AB8C4B]/30 bg-[#AB8C4B]/5 p-4"
          >
            <input
              class="h-4 w-4 mt-0.5 disabled:opacity-50 disabled:cursor-not-allowed"
              id="is-master"
              type="checkbox"
            />
            <label
              class="text-sm"
              for="is-master"
            >
              <span
                class="font-medium"
              >
                Category representative (master)
              </span>
              <p
                class="text-sm text-gray-500 mt-0.5"
              >
                The master is shown as the category card on the booking page. Its image and name represent the entire category. Only one session type per category can be the master.
              </p>
            </label>
          </div>
          <div
            class="flex items-center gap-3 pt-2"
          >
            <input
              class="h-4 w-4"
              id="active-toggle"
              type="checkbox"
            />
            <label
              class="text-md"
              for="active-toggle"
            >
              Visible to clients (active)
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

